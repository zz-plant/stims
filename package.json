{
  "name": "stims",
  "description": "Browser-native MilkDrop-inspired visualizer with curated presets, live editing, and import/export.",
  "version": "1.0.0",
  "type": "module",
  "homepage": "https://toil.fyi",
  "repository": {
    "type": "git",
    "url": "https://github.com/zz-plant/stims.git"
  },
  "bugs": {
    "url": "https://github.com/zz-plant/stims/issues"
  },
  "keywords": [
    "milkdrop",
    "milkdrop-successor",
    "visualizer",
    "audio-reactive",
    "threejs",
    "webgl",
    "webgpu",
    "generative-art",
    "creative-coding",
    "preset-browser"
  ],
  "packageManager": "bun@1.3.8",
  "scripts": {
    "test": "bun run scripts/run-tests.ts",
    "test:fast": "bun run scripts/run-tests.ts --profile fast",
    "test:unit": "bun run scripts/run-tests.ts --profile unit",
    "test:integration": "bun run scripts/run-tests.ts --profile integration",
    "test:compat": "bun run scripts/run-tests.ts --profile compat",
    "check:accessibility": "bun run scripts/accessibility-audit.ts",
    "test:watch": "bun run scripts/run-tests.ts --watch",
    "biome:check": "bash scripts/run-biome.sh check",
    "lint": "bash scripts/run-biome.sh lint",
    "lint:fix": "bash scripts/run-biome.sh lint --write",
    "format": "bash scripts/run-biome.sh format --write",
    "format:check": "bash scripts/run-biome.sh format",
    "typecheck": "node --max-old-space-size=4096 ./node_modules/typescript/bin/tsc --noEmit",
    "typecheck:watch": "node --max-old-space-size=4096 ./node_modules/typescript/bin/tsc --noEmit --watch",
    "dev": "node --max-old-space-size=4096 ./node_modules/vite/bin/vite.js",
    "dev:host": "node --max-old-space-size=4096 ./node_modules/vite/bin/vite.js --host",
    "dev:check": "bun scripts/dev-check.mjs || node scripts/dev-check.mjs",
    "play:toy": "bun run scripts/play-toy.ts",
    "doctor": "bun run setup:codex --status",
    "setup": "mise trust && bun run setup:codex",
    "setup:codex": "bash scripts/codex-setup.sh",
    "session:codex": "bash scripts/codex-session.sh",
    "model:codex": "bash scripts/codex-model-route.sh",
    "agent:status": "bash scripts/codex-setup.sh --status && echo && bash scripts/codex-session.sh --status",
    "agent:verify": "bash scripts/codex-setup.sh --status && bun run check:quick",
    "check": "bun run assets:check && bun run scripts/run-quality-gate.ts",
    "check:all": "bun run scripts/run-quality-gate.ts --all",
    "check:catalog-fidelity": "bun run scripts/check-bundled-catalog-fidelity.ts",
    "check:quick": "bun run scripts/run-quality-gate.ts --quick",
    "check:architecture": "node --max-old-space-size=4096 ./node_modules/dependency-cruiser/bin/dependency-cruise.mjs --config .dependency-cruiser.mjs assets/js scripts tests",
    "check:toys": "bun run scripts/check-toys.ts",
    "check:seo": "bun run scripts/check-seo.ts",
    "build": "bun scripts/build.mjs || node scripts/build.mjs",
    "build:reuse": "bun run build -- --reuse",
    "generate:toys": "bun run scripts/generate-toy-manifest.ts",
    "generate:seo": "bun run scripts/generate-seo.ts",
    "serve:dist": "bun run scripts/serve-dist.ts",
    "preview": "node --max-old-space-size=4096 ./node_modules/vite/bin/vite.js preview --host",
    "cf:whoami": "bunx wrangler whoami",
    "pages:dev": "bun run build && bunx wrangler --config wrangler.toml pages dev dist",
    "pages:deploy": "bun run pages:deploy:production",
    "pages:deploy:preview": "bun run build && bun run scripts/deploy-cloudflare.mjs --preview",
    "pages:deploy:preview:reuse": "bun run build -- --reuse && bun run scripts/deploy-cloudflare.mjs --preview",
    "pages:deploy:production": "bun run build && bun run scripts/deploy-cloudflare.mjs --production",
    "pages:deploy:production:reuse": "bun run build -- --reuse && bun run scripts/deploy-cloudflare.mjs --production",
    "pages:deploy:reuse": "bun run pages:deploy:production:reuse",
    "mcp": "bun run scripts/mcp-server.ts",
    "mcp:check": "bunx wrangler deploy --dry-run --config wrangler.mcp.jsonc",
    "mcp:deploy": "bunx wrangler deploy --config wrangler.mcp.jsonc",
    "mcp:dev": "bunx wrangler dev --config wrangler.mcp.jsonc",
    "parity:diff": "bun run scripts/diff-parity-artifacts.ts",
    "parity:capture": "bun run scripts/capture-visual-reference-suite.ts",
    "parity:capture:corpus": "bun run scripts/capture-certification-corpus.ts",
    "parity:capture:bundled": "bun run scripts/capture-certification-corpus.ts --group bundled-shipped",
    "parity:promote-reference": "bun run scripts/promote-projectm-reference.ts",
    "parity:promote-result": "bun run scripts/promote-parity-suite-result.ts",
    "parity:sync-catalog": "bun run scripts/sync-bundled-catalog-fidelity.ts",
    "parity:suite": "bun run scripts/run-parity-diff-suite.ts",
    "perf:certification-corpus": "bun run scripts/run-certification-corpus-perf-suite.ts",
    "test:agent": "bun run test:integration",
    "postinstall": "bun scripts/postinstall.mjs || node scripts/postinstall.mjs",
    "dev:webgpu": "bun scripts/dev-webgpu.mjs || node scripts/dev-webgpu.mjs",
    "dev:ui": "vite --config vite.config.ui.js",
    "ui:diff": "bun scripts/ui-diff.ts",
    "check:no-ts-nocheck": "bash scripts/check-no-ts-nocheck.sh",
    "check:production-edge": "bash scripts/check_production_edge.sh",
    "assets:check": "bun run scripts/check-assets.ts",
    "assets:generate": "bun run scripts/generate-scenes.ts"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@biomejs/biome": "^2.4.15",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@playwright/test": "^1.60.0",
    "@radix-ui/react-accordion": "^1.2.14",
    "@radix-ui/react-label": "^2.1.10",
    "@radix-ui/react-slot": "^1.3.0",
    "@types/bun": "^1.3.14",
    "@types/node": "^26.0.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.183.1",
    "@vitejs/plugin-react": "^6.0.2",
    "butterchurn-presets": "^2.4.7",
    "dependency-cruiser": "^17.3.9",
    "happy-dom": "^20.9.0",
    "husky": "^9.1.7",
    "lighthouse": "^13.4.0",
    "playwright": "^1.61.0",
    "sharp": "^0.34.5",
    "typescript": "^6.0.3",
    "vite": "8.0.13",
    "wrangler": "^4.92.0"
  },
  "engines": {
    "node": "^22",
    "bun": ">=1.3.0"
  },
  "dependencies": {
    "@cfworker/json-schema": "^4.1.1",
    "@codemirror/autocomplete": "^6.20.2",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/fold": "^0.19.4",
    "@codemirror/language": "^6.12.3",
    "@codemirror/legacy-modes": "^6.5.3",
    "@codemirror/lint": "^6.9.6",
    "@codemirror/search": "^6.7.0",
    "@codemirror/state": "^6.6.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.43.0",
    "browser-fs-access": "^0.38.0",
    "comlink": "^4.4.2",
    "dexie": "^4.3.0",
    "meyda": "^5.6.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "stats-gl": "^4.1.0",
    "three": "^0.183.2",
    "web-haptics": "^0.0.6",
    "yaml": "^2.8.2",
    "zod": "4.4.3"
  },
  "overrides": {
    "@codemirror/language": "6.12.3",
    "@codemirror/view": "6.43.0",
    "zod": "4.4.3"
  }
}
