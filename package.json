{
  "name": "stims",
  "description": "Browser-native MilkDrop-inspired visualizer with curated presets, live editing, and import/export.",
  "version": "1.0.0",
  "type": "module",
  "homepage": "https://no.toil.fyi",
  "repository": {
    "type": "git",
    "url": "https://github.com/zz-plant/stims.git"
  },
  "bugs": {
    "url": "https://github.com/zz-plant/stims/issues"
  },
  "keywords": [
    "milkdrop",
    "milkdrop-successor",
    "visualizer",
    "audio-reactive",
    "threejs",
    "webgl",
    "webgpu",
    "generative-art",
    "creative-coding",
    "preset-browser"
  ],
  "packageManager": "bun@1.3.8",
  "scripts": {
    "test": "bun run scripts/run-tests.ts",
    "test:unit": "bun run scripts/run-tests.ts --profile unit",
    "test:integration": "bun run scripts/run-tests.ts --profile integration",
    "test:compat": "bun run scripts/run-tests.ts --profile compat",
    "test:compat:full": "bun run scripts/run-tests.ts --profile compat-full",
    "test:watch": "bun run scripts/run-tests.ts --watch",
    "lint": "biome lint assets scripts tests",
    "lint:fix": "biome check --write assets scripts tests",
    "format": "biome format --write assets scripts tests",
    "format:check": "biome format assets scripts tests",
    "typecheck": "tsc --noEmit",
    "typecheck:watch": "tsc --noEmit --watch",
    "dev": "vite",
    "dev:host": "vite --host",
    "dev:check": "bun scripts/dev-check.mjs || node scripts/dev-check.mjs",
    "play:toy": "bun run scripts/play-toy.ts",
    "setup:codex": "bash scripts/codex-setup.sh",
    "check": "bun run scripts/run-quality-gate.ts",
    "check:catalog-fidelity": "bun run scripts/check-bundled-catalog-fidelity.ts",
    "check:quick": "bun run scripts/run-quality-gate.ts --quick",
    "check:toys": "bun run scripts/check-toys.ts",
    "check:seo": "bun run scripts/check-seo.ts",
    "build": "bun scripts/build.mjs || node scripts/build.mjs",
    "build:reuse": "bun run build -- --reuse",
    "generate:toys": "bun run scripts/generate-toy-manifest.ts",
    "generate:seo": "bun run scripts/generate-seo.ts",
    "serve:dist": "bun run scripts/serve-dist.ts",
    "preview": "vite preview --host",
    "cf:whoami": "bunx wrangler whoami",
    "pages:dev": "bun run build && bunx wrangler pages dev dist",
    "pages:deploy": "bun run pages:deploy:production",
    "pages:deploy:preview": "bun run build && bun run scripts/deploy-cloudflare.mjs --preview",
    "pages:deploy:preview:reuse": "bun run build -- --reuse && bun run scripts/deploy-cloudflare.mjs --preview",
    "pages:deploy:production": "bun run build && bun run scripts/deploy-cloudflare.mjs --production",
    "pages:deploy:production:reuse": "bun run build -- --reuse && bun run scripts/deploy-cloudflare.mjs --production",
    "pages:deploy:reuse": "bun run pages:deploy:production:reuse",
    "mcp": "bun run scripts/mcp-server.ts",
    "mcp:check": "bunx wrangler deploy --dry-run --config wrangler.mcp.jsonc",
    "mcp:deploy": "bunx wrangler deploy --config wrangler.mcp.jsonc",
    "mcp:dev": "bunx wrangler dev --config wrangler.mcp.jsonc",
    "parity:diff": "bun run scripts/diff-parity-artifacts.ts",
    "parity:promote-reference": "bun run scripts/promote-projectm-reference.ts",
    "parity:promote-result": "bun run scripts/promote-parity-suite-result.ts",
    "parity:sync-catalog": "bun run scripts/sync-bundled-catalog-fidelity.ts",
    "parity:suite": "bun run scripts/run-parity-diff-suite.ts",
    "test:agent": "bun run test:integration",
    "prepare": "husky install",
    "postinstall": "bun scripts/postinstall.mjs || node scripts/postinstall.mjs",
    "dev:webgpu": "bun scripts/dev-webgpu.mjs || node scripts/dev-webgpu.mjs",
    "check:no-ts-nocheck": "bash scripts/check-no-ts-nocheck.sh"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.15",
    "@playwright/test": "^1.58.2",
    "@types/bun": "^1.3.9",
    "@types/node": "^25.2.3",
    "@types/three": "^0.182.0",
    "happy-dom": "^20.6.1",
    "husky": "^9.1.7",
    "playwright": "^1.58.2",
    "typescript": "^5.9.3",
    "vite": "7.3.1",
    "wrangler": "^4.65.0"
  },
  "engines": {
    "node": "^22",
    "bun": ">=1.3.0"
  },
  "dependencies": {
    "@cfworker/json-schema": "^4.1.1",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/language": "^6.12.2",
    "@codemirror/legacy-modes": "^6.5.2",
    "@codemirror/lint": "^6.9.5",
    "@codemirror/search": "^6.6.0",
    "@codemirror/state": "^6.6.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.40.0",
    "@modelcontextprotocol/sdk": "^1.26.0",
    "sharp": "^0.34.5",
    "three": "^0.182.0",
    "web-haptics": "^0.0.6",
    "yaml": "^2.8.2",
    "zod": "^4.3.6"
  }
}
