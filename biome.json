{
  "$schema": "https://biomejs.dev/schemas/2.5.0/schema.json",
  "files": {
    "maxSize": 2097152
  },
  "linter": {
    "enabled": true,
    "rules": {
      "preset": "recommended",
      "style": {
        "noNonNullAssertion": "warn",
        "noDescendingSpecificity": "off"
      },
      "correctness": {
        "noUnusedVariables": "warn"
      },
      "suspicious": {
        "useIterableCallbackReturn": "off",
        "noDuplicateProperties": "off"
      }
    }
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 80
  },
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single"
    }
  },
  "overrides": [
    {
      "includes": ["src/js/lib/**"],
      "linter": {
        "enabled": false
      },
      "formatter": {
        "enabled": false
      }
    },
    {
      "includes": ["src/js/data/toy-manifest.ts"],
      "formatter": {
        "enabled": false
      }
    },
    {
      "includes": ["terminal/**"],
      "linter": {
        "rules": {
          "style": {
            "noNonNullAssertion": "off"
          }
        }
      }
    },
    {
      "includes": [
        "public/toys.json",
        "public/milkdrop-presets/catalog.json",
        "screenshots/parity/**",
        "tests/accessibility/**"
      ],
      "formatter": {
        "enabled": false
      },
      "linter": {
        "enabled": false
      }
    }
  ]
}
