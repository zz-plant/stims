shape_2_border_r=0.92
shape_2_border_g=0.84
shape_2_border_b=1
shape_2_additive=1
shape_2_thickoutline=1

per_frame_1=shape_1_rad = 0.18 + bass_att * 0.05
per_frame_2=shape_2_rad = 0.3 + treble_att * 0.06
per_frame_3=rot = rot + 0.001 + beat_pulse * 0.003
per_frame_4=wave_scale = 0.88 + mids_att * 0.06

per_pixel_1=warp = warp + sin(rad * 8 + time * 0.45) * 0.014

