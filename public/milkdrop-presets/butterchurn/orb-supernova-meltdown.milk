[warp_shader]
shader_body { 
  vec4 tmpvar_1;
  tmpvar_1.w = 1.0;
  tmpvar_1.xyz = (texture (sampler_fc_main, uv).xyz * 0.8);
  ret = tmpvar_1.xyz;
 }

[comp_shader]
shader_body { 
  vec3 ret_1;
  vec2 tmpvar_2;
  tmpvar_2 = (((uv - 0.5) * vec2(1.0, -1.0)) + 0.5);
  ret_1 = (mix (texture (sampler_main, uv).xyz, texture (sampler_main, tmpvar_2).xyz, vec3(0.5, 0.5, 0.5)) + (mix (texture (sampler_main, 
    ((texture (sampler_blur1, uv).xyz * scale1) + bias1)
  .xy).xyz, texture (sampler_main, 
    ((texture (sampler_blur1, tmpvar_2).xyz * scale1) + bias1)
  .xy).xyz, vec3(0.5, 0.5, 0.5)) * 0.5));
  ret_1 = ((ret_1 * 2.0) * ret_1);
  vec4 tmpvar_3;
  tmpvar_3.w = 1.0;
  tmpvar_3.xyz = ret_1;
  ret = tmpvar_3.xyz;
 }
