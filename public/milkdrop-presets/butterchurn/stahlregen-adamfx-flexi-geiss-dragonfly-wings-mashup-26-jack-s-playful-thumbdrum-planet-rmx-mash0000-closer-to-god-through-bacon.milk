[comp_shader]
float xlat_mutablea;
float xlat_mutableb;
float xlat_mutablec;
 shader_body { 
  vec2 uv_1;
  vec3 ret_2;
  uv_1 = ((0.5 + (
    (uv - 0.5)
   * vec2(0.75, -0.9))) - vec2(0.0, 0.05));
  vec3 tmpvar_3;
  tmpvar_3 = (((
    (((texture (sampler_blur3, uv_1).xyz * scale3) + bias3) + ((texture (sampler_blur2, uv_1).xyz * scale2) + bias2))
