  sand_1 = (dot (texture (sampler_noise_lq, (
    ((uv_orig * texsize.xy) * texsize_noise_lq.zw)
   + rand_frame.xy)).xyz, abs(
    ((((tmpvar_4.xyz * scale1) + bias1) - ((texture (sampler_blur2, uv).xyz * scale2) + bias2)) - ((texture (sampler_blur3, uv).xyz * scale3) + bias3))
  )) + ((tmpvar_4.xyz * scale1) + bias1).x);
  ret_2 = (tmpvar_3.xyz + (0.1 + (
