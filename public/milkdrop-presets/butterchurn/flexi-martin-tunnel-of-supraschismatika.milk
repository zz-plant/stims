  )) - (4.0 * tmpvar_8));
  vec3 tmpvar_9;
  tmpvar_9 = pow (((
    (2.0 * (clamp ((0.02 / 
      sqrt(dot (uv_1, uv_1))
    ), 0.0, 1.0) * hue_shader))
   * 
    ((texture (sampler_main, tmpvar_3) * 4.0).xyz + 1.0)
  ) - 0.04), vec3(0.8, 0.8, 0.8));
  vec4 tmpvar_10;
  tmpvar_10.w = 1.0;
  tmpvar_10.xyz = mix (tmpvar_9, tmpvar_9.zxy, vec3(q19)).zxy;
