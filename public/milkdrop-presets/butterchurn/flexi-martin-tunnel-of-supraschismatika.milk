  vec2 tmpvar_3;
  tmpvar_3 = fract(xlat_mutablers);
  vec2 tmpvar_4;
  tmpvar_4.y = 0.0;
  tmpvar_4.x = texsize.z;
  vec2 tmpvar_5;
  tmpvar_5 = (tmpvar_4 * 4.0);
  vec2 tmpvar_6;
  tmpvar_6.x = 0.0;
  tmpvar_6.y = texsize.w;
  vec2 tmpvar_7;
  tmpvar_7 = (tmpvar_6 * 4.0);
  vec2 tmpvar_8;
  tmpvar_8.x = dot (((
    (texture (sampler_blur1, (tmpvar_3 - tmpvar_5)).xyz * scale1)
   + bias1) - (
    (texture (sampler_blur1, (tmpvar_3 + tmpvar_5)).xyz * scale1)
   + bias1)), vec3(0.32, 0.49, 0.29));
  tmpvar_8.y = dot (((
    (texture (sampler_blur1, (tmpvar_3 - tmpvar_7)).xyz * scale1)
   + bias1) - (
    (texture (sampler_blur1, (tmpvar_3 + tmpvar_7)).xyz * scale1)
