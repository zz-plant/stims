[comp_shader]
vec2 xlat_mutablers;
 shader_body { 
  vec2 uv_1;
  uv_1 = (0.5 + ((uv - 0.5) * aspect.xy));
  xlat_mutablers.x = (((ang / 3.14) + (rad * 
