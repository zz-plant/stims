  xlat_mutablenoise = (tmpvar_5.xyz * vec3(greaterThanEqual (tmpvar_5.xyz, vec3(0.84, 0.84, 0.84))));
  xlat_mutableret1 = xlat_mutablenoise;
  z_1 = (0.4 / abs(tmpvar_2.x));
  xlat_mutablers.y = (tmpvar_2.y * z_1);
  xlat_mutablers.x = (z_1 + tmpvar_4);
  vec4 tmpvar_6;
  tmpvar_6 = texture (sampler_pw_noise_lq, (xlat_mutablers / 28.0));
  xlat_mutablenoise = (tmpvar_6.xyz * vec3(greaterThanEqual (tmpvar_6.xyz, vec3(0.84, 0.84, 0.84))));
  xlat_mutableret1 = (xlat_mutableret1 + xlat_mutablenoise);
  vec4 tmpvar_7;
