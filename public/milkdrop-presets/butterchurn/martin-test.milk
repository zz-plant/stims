[warp_shader]
uniform sampler2D sampler_moss1;
 shader_body { 
  vec2 uv_1;
  uv_1 = (((
    (uv - 0.5)
   / texsize_moss1.xy) * texsize.xy) + 0.5);
  vec4 tmpvar_2;
  tmpvar_2.w = 1.0;
  tmpvar_2.xyz = (((
    (texture (sampler_moss1, uv_1) * float((uv_1.x < 1.0)))
   * 
    float((uv_1.x > 0.0))
  ) * float(
    (uv_1.y < 1.0)
  )) * float((uv_1.y > 0.0))).xyz;
  ret = tmpvar_2.xyz;
 }

[comp_shader]
shader_body { 
  vec4 tmpvar_1;
  tmpvar_1.w = 1.0;
  tmpvar_1.xyz = texture (sampler_main, uv).xyz;
  ret = tmpvar_1.xyz;
 }
