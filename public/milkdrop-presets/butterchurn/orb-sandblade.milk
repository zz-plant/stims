  float tmpvar_9;
  tmpvar_9 = (1.0/(texsize.y));
  tmpvar_7.y = 0.0;
  xlat_varoutput_1 = (0.05 * texture (sampler_main, (uv + tmpvar_7))).xyz;
  vec2 tmpvar_10;
