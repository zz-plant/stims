[warp_shader]
shader_body { 
  vec3 ret_1;
  vec4 tmpvar_2;
  tmpvar_2 = texture (sampler_fc_main, uv);
  ret_1 = tmpvar_2.xyz;
  if ((((tmpvar_2.x + tmpvar_2.y) + tmpvar_2.z) < ((
    ((mid + bass) + treb)
   / 3.0) * 0.3))) {
    ret_1 = (tmpvar_2.xyz + vec3(0.6, 0.6, 0.6));
  } else {
    ret_1 = ((ret_1 - 0.005) * 0.99);
  };
  vec4 tmpvar_3;
  tmpvar_3.w = 1.0;
  tmpvar_3.xyz = ret_1;
  ret = tmpvar_3.xyz;
 }
