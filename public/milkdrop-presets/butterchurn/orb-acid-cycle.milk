shader_body { 
  vec2 tmpvar_1;
  tmpvar_1.x = -(q3);
  tmpvar_1.y = q3;
  vec4 tmpvar_2;
  tmpvar_2.w = 1.0;
  tmpvar_2.xyz = (texture (sampler_main, (uv + (texsize.zw * tmpvar_1))).xyz - 0.004);
