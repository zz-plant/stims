 }

[comp_shader]
shader_body { 
  vec4 tmpvar_1;
  tmpvar_1.w = 1.0;
  tmpvar_1.xyz = mix ((texture (sampler_fc_main, uv).x * pow (hue_shader.zxy, vec3(4.0, 4.0, 4.0))), mix ((
    (hue_shader * hue_shader)
   * 1.2), pow (hue_shader, vec3(6.0, 6.0, 6.0)).yzx, texture (sampler_main, uv).zzz), ((texture (sampler_blur1, uv).xyz * scale1) + bias1).yyy);
  ret = tmpvar_1.xyz;
 }
