[warp_shader]
shader_body { 
  vec2 uv_1;
  uv_1.y = uv.y;
  vec3 ret_2;
  vec2 tmpvar_3;
  tmpvar_3.x = roam_cos.x;
  tmpvar_3.y = roam_sin.x;
  vec2 tmpvar_4;
  tmpvar_4 = (texsize_noise_lq.zw * texsize.xy);
  uv_1.x = (uv.x + ((0.02 * 
    ((texture (sampler_noise_lq, ((
      (0.1 * tmpvar_4)
     * uv) + (tmpvar_3 * 0.1))).y * 2.0) - 1.0)
  ) * aspect.x));
  vec2 tmpvar_5;
  tmpvar_5.x = roam_sin.y;
  tmpvar_5.y = -(roam_cos.y);
  uv_1.x = (uv_1.x + ((0.04 * 
    ((texture (sampler_noise_lq, ((
      (0.0125 * tmpvar_4)
     * uv_1) + (tmpvar_5 * 0.03))).z * 2.0) - 1.0)
  ) * aspect.x));
  vec4 tmpvar_6;
  tmpvar_6 = texture (sampler_main, uv_1);
  ret_2.xy = tmpvar_6.xy;
  ret_2.z = (tmpvar_6.z * 0.97);
