  vec2 tmpvar_3;
  tmpvar_3.x = slow_roam_cos.x;
  tmpvar_3.y = slow_roam_sin.y;
  ret_1 = ((pow (tmpvar_2.z, 0.5) * (1.0 - texture (sampler_seaweed, 
    (tmpvar_3 + (vec2(0.1, 0.0) * tmpvar_2.z))
  ))).xyz + (fract(
    (tmpvar_2.z * 126.0)
  ) * 0.07));
  ret_1 = (ret_1 * (abs(
    (uv.y - 0.5)
  ) * 6.0));
  ret_1 = (ret_1 * 0.8);
  vec4 tmpvar_4;
  tmpvar_4.w = 1.0;
  tmpvar_4.xyz = ret_1;
  ret = tmpvar_4.xyz;
 }
