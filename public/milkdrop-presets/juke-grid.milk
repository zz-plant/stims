per_frame_1=rot = rot + 0.01 + treble_att * 0.016
per_frame_2=wave_y = 0.5 + sin(time * 0.72) * 0.08
per_frame_3=shape_1_x = 0.3 + sin(time * 1.1) * 0.18
per_frame_4=shape_2_x = 0.7 - sin(time * 1.1) * 0.18

per_pixel_1=warp = warp + sin(x * 24 + time * 1.5) * 0.03

