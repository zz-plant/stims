wave_y=0.5
wave_mystery=0.18
wave_thick=1.4
wave_additive=1
wave_brighten=1
mesh_density=30
mesh_alpha=0.26
mesh_r=0.18
mesh_g=0.78
mesh_b=0.92
bg_r=0.02
bg_g=0.02
bg_b=0.05
shape_1_enabled=1
shape_1_sides=4
