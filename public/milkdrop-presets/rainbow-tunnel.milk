per_frame_1=zoom = 1.04 + bass_att * 0.08
per_frame_2=rot = rot + 0.012 + treble_att * 0.018
per_frame_3=wave_x = 0.5 + sin(time * 0.34) * 0.08
per_frame_4=wave_y = 0.5 + cos(time * 0.26) * 0.08

per_pixel_1=warp = warp + sin(rad * 19 - time * 1.15) * 0.04

